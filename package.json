{
  "name": "react-native-kline-chart",
  "version": "0.1.0",
  "description": "High-performance K-line (Candlestick) chart for React Native, powered by Skia",
  "main": "lib/commonjs/index.js",
  "module": "lib/module/index.js",
  "types": "lib/typescript/index.d.ts",
  "react-native": "src/index.ts",
  "source": "src/index.ts",
  "author": "xinKyy",
  "files": [
    "src",
    "lib",
    "!**/__tests__"
  ],
  "scripts": {
    "build": "bob build",
    "prepare": "bob build",
    "typescript": "tsc --noEmit",
    "lint": "eslint src/"
  },
  "keywords": [
    "react-native",
    "kline",
    "candlestick",
    "chart",
    "skia",
    "trading",
    "finance"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/xinKyy/react-native-kline-chart"
  },
  "license": "MIT",
  "peerDependencies": {
    "@shopify/react-native-skia": ">=2.0.0",
    "react": ">=19.0.0",
    "react-native": ">=0.78.0",
    "react-native-gesture-handler": ">=2.20.0",
    "react-native-reanimated": ">=4.0.0",
    "react-native-worklets": ">=0.7.0"
  },
  "devDependencies": {
    "@shopify/react-native-skia": "^2.5.3",
    "@types/react": "^19.2.14",
    "react": "^19.0.0",
    "react-native": "^0.84.0",
    "react-native-builder-bob": "^0.35.0",
    "react-native-gesture-handler": "^2.30.0",
    "react-native-reanimated": "^4.2.2",
    "typescript": "^5.7.0"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "commonjs",
        {
          "copyFlow": false
        }
      ],
      [
        "module",
        {
          "copyFlow": false
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  }
}
